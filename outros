void monitorSerial(){
  const unsigned long intervaloMonitorSerial = 5000;
  static unsigned long tempoMonitorSerial = 0;

  if(millis() - tempoMonitorSerial >= intervaloMonitorSerial){
    tempoMonitorSerial = millis();
    if(estadoSistema){
      if(distancia == -1){
        Serial.println("Erro ao ler HC-SR04");
      }
      else{
        Serial.print("Distância: ");
        Serial.print(distancia);
        Serial.println(" cm");
      }
      if(isnan(temperatura) || isnan(umidade)){
        Serial.println("Erro ao ler DHT");
      }
      else{
        Serial.print("Temperatura: ");
        Serial.print(temperatura);
        Serial.println("°C");
        Serial.print("Umidade: ");
        Serial.print(umidade);
        Serial.println("%\n");
      }
    }
    else{
      Serial.println("Sistema inativo");
    }
  }
}

void botao(){
  static bool estadoBotao = true;
  static bool estadoBotaoAnterior = true;
  const unsigned long debounce = 10;
  static unsigned long tempoDebounce = 0;

  estadoBotao = digitalRead(BOTAO);

  if(millis() - tempoDebounce >= debounce){
    tempoDebounce = millis();
    if(estadoBotao == false && estadoBotaoAnterior == true){
      estadoSistema = !estadoSistema;
    }
    estadoBotaoAnterior = estadoBotao;
  }
}

void controleLEDs(){
  digitalWrite(LED_VERDE, estadoSistema);
  digitalWrite(LED_VERMELHO, !estadoSistema);
}
