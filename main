#include <WiFi.h>
#include <HTTPClient.h>
#include "secrets.h"
#include <DHT.h>

const char* ssid = WIFI_SSID;
const char* password = WIFI_PASSWORD;

const char* supabaseURL = SUPABASE_URL;
const char* apiKey = API_KEY;

#define BOTAO 13
#define TRIG_PIN 26
#define ECHO_PIN 27
#define LED_VERDE 21
#define LED_VERMELHO 19
#define DHT_PIN 23
#define DHT_TYPE DHT22

DHT dht(DHT_PIN, DHT_TYPE);

float distancia;
float temperatura;
float umidade;

bool estadoSistema = false;

void setup() {
  Serial.begin(115200);
  pinMode(BOTAO, INPUT_PULLUP);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(LED_VERDE, OUTPUT);
  pinMode(LED_VERMELHO, OUTPUT);
  setupWiFi();
  dht.begin();
}

void loop() {
  reconectarWiFi();
  botao();
  controleLEDs();
  if(estadoSistema){
    lerHCSR04();
    lerDHT();
    enviarDados();
  }
  monitorSerial();
}
